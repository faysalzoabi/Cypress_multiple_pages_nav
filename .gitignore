# Vite / cache
# ========================
.vite/
.cache/

# ========================
# Cypress
# ========================
cypress/screenshots/
cypress/videos/
cypress/downloads/
cypress/logs/
cypress/results/

# Cypress cache (local machine only)
cypress/fixtures/*.tmp
cypress.env.json

# ========================
# Environment variables
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# Logs
# ========================
logs/
*.log

# ========================
