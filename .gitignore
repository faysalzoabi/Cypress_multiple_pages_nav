# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# Editor / IDE
# ========================
.vscode/
.idea/
*.swp
*.swo

# ========================
# Testing outputs (optional)
# ========================
coverage/
nyc_output/

